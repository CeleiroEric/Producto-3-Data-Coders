{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "JavaFX Producto 5",
      "request": "launch",
      "mainClass": "datacoders.vista.Main",
      "modulePaths": [
        "${workspaceFolder}/lib/javafx"
      ],
      "classPaths": [
        "${workspaceFolder}/bin",
        "${workspaceFolder}/src",
        "${workspaceFolder}/lib/deps/*"
      ],
      "vmArgs": "--add-modules javafx.controls,javafx.graphics,javafx.base",
      "console": "integratedTerminal"
    }
  ]
}