<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">

    <persistence-unit name="UnidadPersistenciaDataCoders">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>datacoders.modelo.Articulo</class>
        <class>datacoders.modelo.Cliente</class>
        <class>datacoders.modelo.ClienteEstandar</class>
        <class>datacoders.modelo.ClientePremium</class>
        <class>datacoders.modelo.Pedido</class>

        <properties>
            <!-- Configuración de Conexión -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:mysql://localhost:3306/gestion_pedidos?allowPublicKeyRetrieval=true&amp;useSSL=false&amp;serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value="rootsql1.26"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>

            <!-- CONFIGURACIÓN DE SEGURIDAD PARA JDBC MANUAL -->
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.connection.autocommit" value="true"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>